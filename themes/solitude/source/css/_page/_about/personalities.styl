.author-content-item.personalities
  overflow hidden
  position relative
  flex 6
  +maxWidth768()
    min-height 360px

  .title2
    font-size 36px
    font-weight 700
    line-height 1.1

  .image
    position absolute
    right -40px
    bottom -16rem
    transition transform 1s cubic-bezier(.13, .45, .21, 1.02)
    user-select none
    transform scale(0.5)

    +maxWidth768()
      right -70px

  &:hover
    .image
      transform rotate(-15deg) scale(0.7)
